# 有道云翻译 API 密钥
# 申请地址: https://ai.youdao.com/
VITE_YOUDAO_APP_KEY="YOUR_YOUDAO_APP_KEY"
VITE_YOUDAO_APP_SECRET="YOUR_YOUDAO_APP_SECRET"

# 阿里云 DashScope API 密钥
# 用于实时语音识别 (Fun-ASR)
# 申请地址: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY="YOUR_DASHSCOPE_API_KEY"

# DashScope WebSocket 服务地址
DASHSCOPE_WS_URL="wss://dashscope.aliyuncs.com/api-ws/v1/inference"

# 音频配置
AUDIO_SAMPLE_RATE="16000"

# 远程推理服务器 API Key (YOLO + OCR)
REMOTE_API_KEY="YOUR_REMOTE_API_KEY"

# Optional - Gemini AI
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
